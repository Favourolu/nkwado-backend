NODE_ENV=development
PORT=3001
DATABASE_URL=postgresql://user:pass@host:port/nkwado
JWT_SECRET=your-secret-key-here
JWT_EXPIRES_IN=7d
RESEND_API_KEY=your-resend-key
AWS_ACCESS_KEY_ID=your-aws-key
AWS_SECRET_ACCESS_KEY=your-aws-secret
AWS_S3_BUCKET=nkwado-vendor-docs
AWS_REGION=eu-west-1
# "s3" (default) uses real AWS S3; "local" writes uploads to ./uploads for dev without AWS access
FILE_STORAGE_DRIVER=s3
CORS_ORIGIN=http://localhost:3000
# Standard 5-field cron; defaults to every 5 minutes. 6-field (with seconds) also works for testing.
REMINDER_CRON_SCHEDULE=*/5 * * * *
# Set both, then run `npm run prisma:seed`, to create the one ADMIN account (ADMIN isn't
# self-registerable via POST /auth/register). Leave unset to skip the seed.
ADMIN_EMAIL=
ADMIN_PASSWORD=
